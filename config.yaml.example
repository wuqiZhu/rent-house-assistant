# ============================================
# 租房助手 - 用户偏好配置
# 复制此文件为 config.yaml 并填入你的真实配置
# config.yaml 已被 .gitignore 忽略，不会提交到 Git
# ============================================

preferences:
  budget_min: 800
  budget_max: 1200
  area_min: 0
  area_max: 999
  preferred_districts:
    - "朝阳区"
    - "南关区"
  preferred_subway_stations: []
  max_commute_minutes: 30
  workplace_station: "硅谷广场"
  required_facilities:
    - "洗衣机"
    - "独立卫生间"
  preferred_rooms: []

scrapers:
  douban:
    enabled: true
    groups:
      - ["changchun", "长春豆瓣小组"]
      - ["308599", "豆瓣租房小组"]
    cookie: ""
    max_pages: 5
    exclude_keywords:
      - "求租"
    include_keywords:
      - "出租"
      - "租房"
      - "整租"
      - "合租"
      - "转租"
      - "月租"
      - "元/月"
  inboyu:
    enabled: true
    city: "长春"
    request_interval: 3.0
  baletoo:
    enabled: true
    cities:
      - "bj"
      - "sh"
    request_interval: 3.0
  fang:
    enabled: true
    city: "长春"
    max_pages: 3
    request_interval: 5.0

scoring:
  min_score_to_notify: 50

notification:
  dingtalk_webhook: ""
  dingtalk_secret: ""
