# ============================================
# 租房助手 - 用户偏好配置
# 复制此文件为 config.yaml 并填入你的真实配置
# config.yaml 已被 .gitignore 忽略，不会提交到 Git
# ============================================

# ========== 改这一行，切换所有爬虫的城市 ==========
# 可选城市: 北京 上海 广州 深圳 成都 杭州 南京 武汉 天津 重庆
#          长沙 长春 厦门 西安 郑州 大连 沈阳 苏州 佛山
#          哈尔滨 济南 青岛 昆明 贵阳 合肥 福州
# 改这一行 → 所有爬虫自动切换城市，不支持的平台自动跳过
city: "长春"

preferences:
  budget_min: 800
  budget_max: 1200
  area_min: 0
  area_max: 999
  preferred_districts:
    - "朝阳区"
    - "南关区"
  preferred_subway_stations: []
  max_commute_minutes: 30
  workplace_station: "硅谷广场"
  required_facilities:
    - "洗衣机"
    - "独立卫生间"
  preferred_rooms: []

scrapers:
  douban:
    enabled: true
    groups:
      - ["changchun", "长春豆瓣小组"]
      - ["308599", "豆瓣租房小组"]
    cookie: ""
    max_pages: 5
    exclude_keywords:
      - "求租"
    include_keywords:
      - "出租"
      - "租房"
      - "整租"
      - "合租"
      - "转租"
      - "月租"
      - "元/月"
      - "直租"
  inboyu:
    enabled: true
    city: "长春"
    request_interval: 3.0
  baletoo:
    enabled: false
    cities:
      - "bj"
      - "sh"
    request_interval: 3.0
  fang:
    enabled: false
    city: "长春"
    max_pages: 3
    request_interval: 5.0

scoring:
  min_score_to_notify: 30

notification:
  dingtalk_webhook: ""
  dingtalk_secret: ""
